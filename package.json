{
  "name": "robox",
  "version": "0.1.0",
  "private": true,
  "config": {
    "supabaseCliVersion": "2.96.0"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.13"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "supabase:install": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-supabase-cli.ps1",
    "supabase:version": "powershell -ExecutionPolicy Bypass -File ./scripts/run-supabase.ps1 --version",
    "supabase:init": "powershell -ExecutionPolicy Bypass -File ./scripts/run-supabase.ps1 init",
    "supabase:start": "powershell -ExecutionPolicy Bypass -File ./scripts/run-supabase.ps1 start",
    "supabase:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/run-supabase.ps1 stop",
    "supabase:status": "powershell -ExecutionPolicy Bypass -File ./scripts/run-supabase.ps1 status"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
