# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
ALLOWED_EMAILS=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# GitHub (optional, for import rate-limit relief)
GITHUB_TOKEN=

# GitHub OAuth (required for local Supabase GitHub login)
# These are read by the local Supabase stack from supabase/config.toml via env(...) substitution.
# Not needed for cloud Supabase (configure in Dashboard → Authentication → Providers instead).
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
SUPABASE_AUTH_EXTERNAL_GITHUB_REDIRECT_URI=http://127.0.0.1:55421/auth/v1/callback
